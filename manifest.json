{
  "version": "0.1.0-dev",
  "name": "1C AI Assistant",
  "description": "Multi-agent system for solving 1C:Enterprise 8.3 development tasks",
  "system_dependencies": {
    "python": ">=3.12",
    "java": ">=17 (для BSL Language Server, в отдельном контейнере)",
    "git": "any",
    "docker": ">=24.0",
    "docker_compose": ">=2.20"
  },
  "python_dependencies_required": [
    "pydantic>=2.5,<3.0",
    "langgraph>=0.2,<1.0",
    "langchain-core>=0.3,<1.0",
    "mcp>=1.0,<2.0",
    "networkx>=3.0,<4.0",
    "structlog>=24.0,<26.0",
    "lxml>=5.0,<6.0",
    "jinja2>=3.1,<4.0",
    "httpx>=0.27,<1.0",
    "pyyaml>=6.0,<7.0",
    "psycopg[binary]>=3.1,<4.0",
    "fastembed>=0.8,<1.0"
  ],
  "python_dependencies_optional": {
    "ast": ["tree-sitter>=0.25,<1.0", "tree-sitter-bsl>=0.1,<1.0"],
    "sdbl": ["antlr4-python3-runtime>=4.13,<5.0"],
    "qdrant": ["qdrant-client>=1.0,<2.0"],
    "api": ["fastapi>=0.110,<1.0", "uvicorn>=0.27,<1.0"],
    "metrics": ["prometheus-client>=0.20,<1.0"],
    "langsmith": ["langsmith>=0.1,<1.0"]
  },
  "docker_services": [
    {
      "name": "1c-ai-app",
      "purpose": "Python orchestrator + 4 MCP in-process + Facade",
      "build": "docker/Dockerfile.app",
      "ports": ["8000:8000"]
    },
    {
      "name": "1c-ai-bsl-ls",
      "purpose": "BSL Language Server (Java 17), HTTP API на :8080",
      "build": "docker/Dockerfile.bsl-ls",
      "ports": ["8080:8080"]
    },
    {
      "name": "postgres",
      "purpose": "PostgreSQL 16 + pgvector + pg_trgm для persistence и vector search",
      "image": "pgvector/pgvector:pg16",
      "ports": ["5432:5432"]
    }
  ],
  "git_submodules": [
    {
      "name": "bsl-parser-grammar",
      "url": "https://github.com/1c-syntax/bsl-parser.git",
      "license": "LGPL-3.0",
      "purpose": "SDBL .g4 грамматики для генерации парсера"
    }
  ],
  "architecture_adrs": 17,
  "mcp_servers": 5,
  "agent_roles": 6,
  "lifecycle_tools": 7
}
