# .env.example — переменные окружения для 1C AI Assistant.
# Скопируйте в `.env` и отредактируйте. См. ADR-0015, D-2026-07-13-09.

# ─── Persistence (Postgres) ─────────────────────────────────────────────────
# DSN для LangGraph checkpoints (PostgresSaver). Если не задан — MemorySaver.
# Production: postgresql://agent:agent@postgres:5432/agent
DATABASE_URL=postgresql://agent:agent@postgres:5432/agent

# ─── BSL Language Server ────────────────────────────────────────────────────
# Mode: auto (default) | subprocess | http | stub (TD-S8-02).
# auto — subprocess если jar есть, fallback на HTTP, fallback на stub.
# subprocess — прямой java -jar (без Docker, нужен jar: 1c-ai bsl-ls download).
# http — HTTP client к Docker контейнеру (production, BSL_LS_HTTP_URL).
# stub — заглушка (0 diagnostics, для CI/tests без Java).
1C_AI_BSL_LS_MODE=auto
# Путь к bsl-language-server.jar (для subprocess mode).
# Скачайте: 1c-ai bsl-ls download
BSL_LS_JAR=vendor/bsl-ls/bsl-language-server.jar
# URL BSL LS HTTP сервера (для http mode, Docker deployment).
BSL_LS_HTTP_URL=http://1c-ai-bsl-ls:8080
# Timeout для BSL LS запросов (секунды).
BSL_LS_TIMEOUT=60
# JVM options (например, -Xmx512m).
JAVA_OPTS=-Xmx512m

# ─── Vector Store ───────────────────────────────────────────────────────────
# auto (default, TD-S8-03) | pgvector | memory.
# auto — pgvector если DATABASE_URL задан, иначе InMemoryVectorStore (no Postgres).
# pgvector — принудительно PgVectorStore (production, Docker).
# memory — принудительно InMemoryVectorStore (tests/dev).
VECTOR_STORE=auto

# ─── Logging ────────────────────────────────────────────────────────────────
# json (default, production) или text (dev, читаемость).
LOG_FORMAT=json

# ─── Git MCP (для open_pr) ──────────────────────────────────────────────────
# GitHub token для `gh` CLI (git.open_pr tool). Если не задан — open_pr падает
# с FileNotFoundError/instruction. Получить: https://github.com/settings/tokens.
# НЕ хардкодить в коде — только env var.
# GH_TOKEN=ghp_your_token_here

# ─── LLM (ZaiLLM) ───────────────────────────────────────────────────────────
# ZaiLLM использует z-ai CLI subprocess (без внешнего API ключа).
# Если z-ai CLI не установлен — LLM недоступен, plan/generate/review деградируют.
# ZAI_API_KEY=optional_for_future_use

# ─── Project root ───────────────────────────────────────────────────────────
# Корневая директория проекта (где paths.env). По умолчанию — текущая директория.
# ONEC_AI_PROJECT=/app

# ─── Integration tests (CI only) ────────────────────────────────────────────
# DSN для integration-тестов persistence (реальный Postgres).
# TEST_POSTGRES_DSN=postgresql://agent:agent@localhost:5432/agent_test
# Путь к git-репозиторию для integration-тестов git MCP.
# TEST_GIT_REPO=/path/to/test/repo
# URL BSL LS для integration-тестов (если запущен локально).
# BSL_LS_HTTP_URL=http://localhost:8080
